			alias="LogCommentDTO" /> 
		<typeAlias type="com.ddd.app.admin.dto.AdminDTO"
			alias="AdminDTO" />
		<typeAlias type="com.ddd.app.admin.dto.AdminUserDTO"
			alias="AdminUserDTO" />
		<typeAlias type="com.ddd.app.dogarchive.dto.ArchiveDeleteDTO"
			alias="ArchiveDeleteDTO" />
		<typeAlias type="com.ddd.app.dogarchive.dto.ArchiveListDTO"
