		<!-- <mapper resource="com/ddd/mapper/MypageCCareMapper.xml" /> -->
		<!-- <mapper resource="com/ddd/mapper/MypageMatchingResultMapper.xml" /> -->
		<mapper resource="com/ddd/mapper/MypageCInfoMapper.xml" />
		<mapper resource="com/ddd/mapper/MypageSInfoMapper.xml" />
		<mapper resource="com/ddd/mapper/MypageLogMapper.xml" />
		<!-- <mapper resource="com/ddd/mapper/InquiryMapper.xml" /> -->
		<mapper resource="com/ddd/mapper/mainMapper.xml" />
		<mapper resource="com/ddd/mapper/ReportMapper.xml" />
		<mapper resource="com/ddd/mapper/CareMapper.xml" />
	</mappers>
	


