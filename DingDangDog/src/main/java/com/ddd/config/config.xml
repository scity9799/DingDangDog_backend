			alias="CareDetailDTO" />
		<typeAlias type="com.ddd.app.dogcare.dto.CareDTO"
			alias="CareDTO" />
		<typeAlias type="com.ddd.app.dogcare.dto.CareListDTO"
			alias="CareListDTO" />
		<typeAlias type="com.ddd.app.admin.dto.AdminArchiveDTO"
			alias="AdminArchiveDTO" />
		<typeAlias type="com.ddd.app.admin.dto.AdminCareDTO"
			alias="AdminCareDTO" />
		<typeAlias type="com.ddd.app.admin.dto.AdminLogDTO"
			alias="AdminLogDTO" />
		<!-- <typeAlias type="com.ddd.app.inquiry.dto.InquiryListDTO"
			alias="InquiryListDTO" />
		<typeAlias type="com.ddd.app.inquiry.dto.InquiryDetailDTO"
			alias="InquiryDetailDTO" />
		<typeAlias type="com.ddd.app.inquiry.dto.InquiryWritingDTO"
			alias="InquiryWritingDTO" />
		<typeAlias type="com.ddd.app.mypage.dto.MypageCcareDTO"
			alias="MypageCcareDTO" />  -->
		<typeAlias type="com.ddd.app.mypage.dto.MypageScareDTO"
			alias="MypageScareDTO" />
		<typeAlias type="com.ddd.app.mypage.dto.MyPageDogMatchingDTO"
			alias="MyPageDogMatchingDTO" />
		<typeAlias type="com.ddd.app.mypage.dto.MypageSInfoDTO"
			alias="MypageSDTO" />
		<typeAlias type="com.ddd.app.mypage.dto.MypageLogDTO"
			alias="MypageLogDTO" />
		<typeAlias type="com.ddd.app.main.dto.mainCareDTO"
			alias="mainCareDTO" />
		<typeAlias type="com.ddd.app.main.dto.mainArchiveDTO"
			alias="mainArchiveDTO" />
		<typeAlias type="com.ddd.app.report.dto.ReportDTO"
			alias="ReportDTO" />
	</typeAliases>

	<environments default="oracle">
		<environment id="oracle">
			<transactionManager type="JDBC"></transactionManager>
			<dataSource type="POOLED">
				<property name="driver" value="oracle.jdbc.OracleDriver"></property>
				<property name="url"
					value="jdbc:oracle:thin:@localhost:1521/xe"></property>
				<property name="username" value="dingdong"></property>
				<property name="password" value="dog1234"></property>
			</dataSource>
		</environment>
	</environments>

	<!-- Mapper.xml 등록 추후 필요 -->
	<mappers>
		<mapper resource="com/ddd/mapper/UserMapper.xml" />
		<mapper resource="com/ddd/mapper/LogMapper.xml" />
		<!-- <mapper resource="com/ddd/mapper/MatchingMapper.xml" /> -->
