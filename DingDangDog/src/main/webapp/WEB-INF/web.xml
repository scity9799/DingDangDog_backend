<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	version="4.0">
	<display-name>DingDangDog</display-name>
	<welcome-file-list>
		<welcome-file>index.html</welcome-file>
		<welcome-file>index.htm</welcome-file>
		<welcome-file>index.jsp</welcome-file>
		<welcome-file>index.xhtml</welcome-file>
		<welcome-file>default.html</welcome-file>
		<welcome-file>default.htm</welcome-file>
		<welcome-file>default.jsp</welcome-file>
		<welcome-file>default.xhtml</welcome-file>
	</welcome-file-list>


	<servlet>
		<servlet-name>User</servlet-name>
		<servlet-class>com.ddd.app.user.controller.UserFrontController</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>User</servlet-name>
		<url-pattern>*.us</url-pattern>
	</servlet-mapping>

	<!-- 멍로그 매핑 -->
	<servlet>
		<servlet-name>log</servlet-name>
		<servlet-class>com.ddd.app.doglog.controller.LogController</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>log</servlet-name>
		<url-pattern>*.lo</url-pattern>
	</servlet-mapping>

	<!-- 멍! 케어 매핑 -->
	<servlet>
		<servlet-name>care</servlet-name>
		<servlet-class>com.ddd.app.dogcare.controller.CareFrontController</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>care</servlet-name>
		<url-pattern>*.care</url-pattern>
	</servlet-mapping>

	<!-- 관리자 매핑 -->
	<servlet>
		<servlet-name>admin</servlet-name>
		<servlet-class>com.ddd.app.admin.controller.AdminFrontController</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>admin</servlet-name>
		<url-pattern>*.ad</url-pattern>
	</servlet-mapping>
</web-app>